<div class="auth-wrap">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-5 col-lg-4">
        <div class="auth-card">
          <div class="auth-logo mb-1">Event<span>Flow</span></div>
          <h3 class="mb-1" style="font-size:1.35rem;font-weight:800;">Welcome back</h3>
          <p style="color:var(--ef-muted);font-size:0.875rem;" class="mb-4">Log in to manage your bookings.</p>

          <% if (errors && errors.length) { %>
            <div class="alert alert-danger mb-3">
              <% errors.forEach(function(e) { %>
                <div class="d-flex align-items-start gap-2">
                  <i class="bi bi-exclamation-circle-fill mt-1" style="flex-shrink:0;"></i>
                  <span><%= e.msg %></span>
                </div>
              <% }) %>
            </div>
          <% } %>

          <form action="/auth/login" method="POST" novalidate>
            <div class="mb-3">
              <label class="form-label">Email address</label>
              <input type="email" name="email" class="form-control"
                     placeholder="you@example.com"
                     value="<%= formData.email || '' %>" required />
            </div>
            <div class="mb-4">
              <label class="form-label">Password</label>
              <input type="password" name="password" class="form-control"
                     placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">
              Log in <i class="bi bi-arrow-right ms-1"></i>
            </button>
          </form>

          <p class="text-center mt-4 mb-0" style="font-size:0.85rem;color:var(--ef-muted);">
            No account? <a href="/auth/register" style="color:var(--ef-accent);">Sign up for free</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
