<% if (flashMessages.success && flashMessages.success.length) { %>
  <div class="container mt-3">
    <% flashMessages.success.forEach(function(msg) { %>
      <div class="alert alert-success alert-dismissible fade show auto-dismiss" role="alert">
        <i class="bi bi-check-circle-fill me-1"></i> <%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  </div>
<% } %>

<% if (flashMessages.error && flashMessages.error.length) { %>
  <div class="container mt-3">
    <% flashMessages.error.forEach(function(msg) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  </div>
<% } %>

<% if (flashMessages.info && flashMessages.info.length) { %>
  <div class="container mt-3">
    <% flashMessages.info.forEach(function(msg) { %>
      <div class="alert alert-info alert-dismissible fade show auto-dismiss" role="alert">
        <i class="bi bi-info-circle-fill me-1"></i> <%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  </div>
<% } %>
