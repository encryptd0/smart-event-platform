<%
  const available = (event.capacity || 0) - (event.ticketsBooked || 0);
  const soldOut = available <= 0;
  const eventDate = new Date(event.date);
%>
<div class="event-card">
  <div class="event-image-wrap">
    <img src="<%= event.imageUrl %>" alt="<%= event.title %>" class="event-image"
         onerror="this.onerror=null;this.src='https://placehold.co/600x400/1A0000/CC0000?text=EventFlow';" />
    <div class="image-overlay"></div>
    <div style="position:absolute;top:0.75rem;right:0.75rem;">
      <% if (soldOut) { %>
        <span class="badge bg-danger">Sold out</span>
      <% } else { %>
        <span class="badge" style="background:rgba(0,0,0,0.6);color:#fff;backdrop-filter:blur(4px);">
          <i class="bi bi-ticket" style="color:var(--ef-accent);"></i> <%= available %> left
        </span>
      <% } %>
    </div>
  </div>

  <div class="card-body">
    <span class="category-badge mb-2 d-inline-block"><%= event.category %></span>

    <h5 class="event-title"><%= event.title %></h5>

    <div class="event-meta mb-2">
      <div>
        <i class="bi bi-calendar3"></i>
        <%= eventDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
        · <%= eventDate.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
      </div>
      <div><i class="bi bi-geo-alt"></i> <%= event.location %></div>
    </div>

    <p class="flex-grow-1" style="font-size:0.82rem;color:var(--ef-muted);line-height:1.5;">
      <%= event.description.length > 100 ? event.description.slice(0, 100) + '…' : event.description %>
    </p>

    <div class="d-flex justify-content-between align-items-center mt-auto pt-2" style="border-top:1px solid var(--ef-border);">
      <span class="price-tag">
        <% if ((event.price || 0) > 0) { %>R<%= Number(event.price).toFixed(2) %><% } else { %>Free<% } %>
      </span>
      <a href="/events/<%= event._id %>" class="btn btn-sm btn-outline-primary">
        View <i class="bi bi-arrow-right"></i>
      </a>
    </div>
  </div>
</div>
