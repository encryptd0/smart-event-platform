<%
  const eventDate = new Date(event.date);
  const isPast = eventDate.getTime() < Date.now();
  const available = event.capacity - event.ticketsBooked;
  const soldOut = available <= 0;
  const pct = Math.min(100, (event.ticketsBooked / event.capacity) * 100);
%>
<div class="container py-4">
  <a href="/" class="d-inline-flex align-items-center gap-1 mb-3" style="color:var(--ef-muted);font-size:0.875rem;">
    <i class="bi bi-arrow-left"></i> All events
  </a>

  <div class="row g-4">
    <!-- Left: image + details -->
    <div class="col-lg-7">
      <div style="border-radius:var(--ef-radius-lg);overflow:hidden;border:1px solid var(--ef-border);">
        <img src="<%= event.imageUrl %>" alt="<%= event.title %>"
             style="width:100%;height:340px;object-fit:cover;display:block;background:#1A0000;"
             onerror="this.onerror=null;this.src='https://placehold.co/800x400/1A0000/CC0000?text=EventFlow';" />
      </div>

      <div class="mt-3 d-flex align-items-center gap-2 flex-wrap">
        <span class="category-badge"><%= event.category %></span>
        <% if (soldOut) { %>
          <span class="badge bg-danger">Sold out</span>
        <% } else if (isPast) { %>
          <span class="badge bg-secondary">Past event</span>
        <% } else { %>
          <span class="badge" style="background:rgba(255,215,0,0.12);color:var(--ef-accent);border:1px solid rgba(255,215,0,0.25);">
            <i class="bi bi-ticket me-1"></i><%= available %> tickets available
          </span>
        <% } %>
      </div>

      <h2 class="mt-3 mb-2" style="font-weight:800;letter-spacing:-0.03em;"><%= event.title %></h2>

      <div class="d-flex flex-column gap-1 mb-4" style="color:var(--ef-muted);font-size:0.9rem;">
        <div><i class="bi bi-calendar3 me-2" style="color:var(--ef-primary);"></i>
          <%= eventDate.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %>
          at <%= eventDate.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
        </div>
        <div><i class="bi bi-geo-alt me-2" style="color:var(--ef-primary);"></i><%= event.location %></div>
      </div>

      <div style="border-top:1px solid var(--ef-border);padding-top:1.5rem;">
        <p class="section-heading">About this event</p>
        <p style="white-space:pre-line;color:var(--ef-text-soft);line-height:1.75;"><%= event.description %></p>
      </div>
    </div>

    <!-- Right: booking card -->
    <div class="col-lg-5">
      <div class="form-card" style="position:sticky;top:80px;">
        <div class="d-flex justify-content-between align-items-baseline mb-1">
          <div style="font-size:2rem;font-weight:800;color:var(--ef-accent);letter-spacing:-0.03em;">
            <% if (event.price > 0) { %>R<%= Number(event.price).toFixed(2) %><% } else { %>Free<% } %>
          </div>
          <span style="color:var(--ef-muted);font-size:0.8rem;">per ticket</span>
        </div>

        <div class="mb-4">
          <div class="capacity-label mb-1">
            <span style="color:var(--ef-text-soft);"><strong style="color:var(--ef-text);"><%= event.ticketsBooked %></strong> booked</span>
            <span style="color:var(--ef-muted);"><%= event.capacity %> capacity</span>
          </div>
          <div class="progress" style="height:6px;">
            <div class="progress-bar <%= pct >= 100 ? 'bg-danger' : pct >= 75 ? 'bg-warning' : '' %>"
                 style="width:<%= pct %>%;"></div>
          </div>
        </div>

        <% if (isPast) { %>
          <div class="alert alert-secondary mb-0">This event has already taken place.</div>
        <% } else if (soldOut) { %>
          <div class="alert alert-danger mb-0">Sorry — this event is fully booked.</div>
        <% } else if (!currentUser) { %>
          <a href="/auth/login" class="btn btn-primary w-100 mb-2">Log in to book</a>
          <p class="text-center mb-0" style="font-size:0.82rem;color:var(--ef-muted);">
            New here? <a href="/auth/register" style="color:var(--ef-accent);">Create an account</a>
          </p>
        <% } else { %>
          <form action="/bookings/<%= event._id %>" method="POST">
            <label class="form-label">Quantity</label>
            <input type="number" name="quantity" class="form-control mb-3"
                   min="1" max="<%= Math.min(20, available) %>" value="1" required />
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-ticket-perforated me-1"></i> Book now
            </button>
          </form>
          <p class="mb-0 mt-2 text-center" style="font-size:0.8rem;color:var(--ef-muted);">
            Cancel any time from your dashboard before the event.
          </p>
        <% } %>
      </div>
    </div>
  </div>
</div>
