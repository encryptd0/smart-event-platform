<%
  // Format ISO date for datetime-local input.
  const toLocalInput = (d) => {
    if (!d) return '';
    const dt = new Date(d);
    if (isNaN(dt.getTime())) return '';
    const pad = (n) => String(n).padStart(2, '0');
    return `${dt.getFullYear()}-${pad(dt.getMonth()+1)}-${pad(dt.getDate())}T${pad(dt.getHours())}:${pad(dt.getMinutes())}`;
  };
  const errorFor = (field) => (errors || []).find((e) => e.path === field || e.param === field);
%>
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <h2 class="mb-3"><%= mode === 'edit' ? 'Edit event' : 'Create event' %></h2>

      <% if (errors && errors.length) { %>
        <div class="alert alert-danger">
          <strong>Please fix the following:</strong>
          <ul class="mb-0">
            <% errors.forEach(function(e) { %>
              <li><%= e.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form action="<%= action %>" method="<%= method %>" class="form-card" novalidate>
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input type="text" name="title" class="form-control"
                 value="<%= formData.title || '' %>" required minlength="3" maxlength="100" />
        </div>

        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea name="description" rows="4" class="form-control" required minlength="10"><%= formData.description || '' %></textarea>
        </div>

        <div class="row g-3">
          <div class="col-md-6 mb-3">
            <label class="form-label">Category</label>
            <select name="category" class="form-select" required>
              <% ['Conference','Workshop','Festival','Private','Other'].forEach(function(c) { %>
                <option value="<%= c %>" <%= formData.category === c ? 'selected' : '' %>><%= c %></option>
              <% }) %>
            </select>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Date & time</label>
            <input type="datetime-local" name="date" class="form-control"
                   value="<%= toLocalInput(formData.date) %>" required />
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Location</label>
          <input type="text" name="location" class="form-control"
                 value="<%= formData.location || '' %>" required />
        </div>

        <div class="row g-3">
          <div class="col-md-4 mb-3">
            <label class="form-label">Capacity</label>
            <input type="number" name="capacity" class="form-control"
                   min="1" value="<%= formData.capacity || '' %>" required />
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label">Price (R)</label>
            <input type="number" step="0.01" name="price" class="form-control"
                   min="0" value="<%= formData.price !== undefined ? formData.price : 0 %>" required />
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label">Image URL <span class="text-muted small">(optional)</span></label>
            <input type="url" name="imageUrl" class="form-control"
                   value="<%= formData.imageUrl || '' %>" placeholder="https://…" />
          </div>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2"></i> <%= mode === 'edit' ? 'Save changes' : 'Create event' %>
          </button>
          <a href="/admin/events" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
