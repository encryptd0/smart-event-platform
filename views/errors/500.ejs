<div class="error-page">
  <div style="width:100%;max-width:600px;">
    <div class="error-code">500</div>
    <h3 class="mt-2 mb-2">Something went wrong</h3>
    <p style="color:var(--ef-muted);margin-bottom:1.5rem;">
      <%= message || 'An unexpected error occurred.' %>
    </p>

    <% if (stack) { %>
      <details class="form-card text-start mb-4">
        <summary style="color:var(--ef-muted);font-size:0.85rem;cursor:pointer;">Stack trace (development only)</summary>
        <pre class="mt-3 mb-0" style="font-size:0.78rem;white-space:pre-wrap;color:var(--ef-text-soft);"><%= stack %></pre>
      </details>
    <% } %>

    <a href="/" class="btn btn-primary">
      <i class="bi bi-house-fill me-1"></i> Back to home
    </a>
  </div>
</div>
