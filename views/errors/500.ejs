<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 text-center">
      <div class="display-1 fw-bold text-danger">500</div>
      <h3 class="mb-2">Something went wrong</h3>
      <p class="text-muted"><%= message || 'An unexpected error occurred.' %></p>

      <% if (stack) { %>
        <details class="text-start mt-4 form-card">
          <summary class="text-muted">Stack trace (development only)</summary>
          <pre class="small mt-3 mb-0" style="white-space: pre-wrap;"><%= stack %></pre>
        </details>
      <% } %>

      <a href="/" class="btn btn-primary mt-4">
        <i class="bi bi-house-fill"></i> Back to home
      </a>
    </div>
  </div>
</div>
