<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="mb-0">Enquiries</h2>
      <p class="text-muted mb-0"><%= enquiries.length %> total</p>
    </div>
  </div>

  <% if (enquiries.length === 0) { %>
    <div class="empty-state form-card">
      <i class="bi bi-inbox"></i>
      <h5>No enquiries yet</h5>
      <p>Submissions from the public contact form appear here.</p>
    </div>
  <% } else { %>
    <div class="form-card p-0">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>From</th>
              <th>Subject</th>
              <th>Status</th>
              <th>Submitted</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% enquiries.forEach(function(e) { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= e.name %></div>
                  <div class="small text-muted"><%= e.email %></div>
                </td>
                <td>
                  <div class="fw-semibold"><%= e.subject %></div>
                  <div class="small text-muted">
                    <%= e.message.length > 80 ? e.message.slice(0, 80) + '…' : e.message %>
                  </div>
                </td>
                <td><span class="status-pill status-<%= e.status %>"><%= e.status %></span></td>
                <td class="small text-muted">
                  <%= new Date(e.createdAt).toLocaleDateString('en-GB') %>
                </td>
                <td class="text-end">
                  <form action="/admin/enquiries/<%= e._id %>/status?_method=PUT" method="POST" class="d-inline">
                    <select name="status" class="form-select form-select-sm d-inline w-auto"
                            onchange="this.form.submit()">
                      <option value="new"      <%= e.status === 'new'      ? 'selected' : '' %>>New</option>
                      <option value="read"     <%= e.status === 'read'     ? 'selected' : '' %>>Read</option>
                      <option value="resolved" <%= e.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                    </select>
                  </form>
                  <form action="/admin/enquiries/<%= e._id %>?_method=DELETE" method="POST" class="d-inline ms-1"
                        data-confirm="Delete this enquiry?">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
