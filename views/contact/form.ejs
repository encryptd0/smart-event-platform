<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
      <div class="form-card">
        <h3 class="mb-1">Get in touch</h3>
        <p class="text-muted mb-4">Questions about an event or booking? Send us a message.</p>

        <% if (errors && errors.length) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% errors.forEach(function(e) { %>
                <li><%= e.msg %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <form action="/contact" method="POST" novalidate>
          <div class="row g-3">
            <div class="col-md-6 mb-2">
              <label class="form-label">Name</label>
              <input type="text" name="name" class="form-control"
                     value="<%= formData.name || '' %>" required />
            </div>
            <div class="col-md-6 mb-2">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control"
                     value="<%= formData.email || '' %>" required />
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Subject</label>
            <input type="text" name="subject" class="form-control"
                   value="<%= formData.subject || '' %>" required />
          </div>

          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea name="message" class="form-control" rows="5" required minlength="10"><%= formData.message || '' %></textarea>
            <div class="form-text">At least 10 characters.</div>
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="bi bi-send"></i> Send enquiry
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
