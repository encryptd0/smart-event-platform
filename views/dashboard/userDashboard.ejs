<div class="container py-4">
  <h2 class="mb-1">My bookings</h2>
  <p class="text-muted mb-4">Manage your tickets and history.</p>

  <% if (bookings.length === 0) { %>
    <div class="empty-state form-card">
      <i class="bi bi-ticket-perforated"></i>
      <h5>No bookings yet</h5>
      <p>Browse upcoming events and book your seat.</p>
      <a href="/" class="btn btn-primary">Browse events</a>
    </div>
  <% } else { %>
    <div class="table-responsive form-card p-0">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Event</th>
            <th>Date</th>
            <th>Quantity</th>
            <th>Total</th>
            <th>Status</th>
            <th>Booked on</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(function(b) {
              const ev = b.event;
              const eventDate = ev ? new Date(ev.date) : null;
              const isPast = eventDate ? eventDate.getTime() < now.getTime() : true;
              const canCancel = b.status === 'confirmed' && ev && !isPast;
          %>
            <tr>
              <td>
                <% if (ev) { %>
                  <a href="/events/<%= ev._id %>" class="fw-semibold text-decoration-none"><%= ev.title %></a>
                  <div class="small text-muted"><%= ev.location %></div>
                <% } else { %>
                  <span class="text-muted"><em>(event removed)</em></span>
                <% } %>
              </td>
              <td>
                <%= eventDate ? eventDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '—' %>
              </td>
              <td><%= b.quantity %></td>
              <td>
                <% if ((b.totalPrice || 0) > 0) { %>R<%= Number(b.totalPrice).toFixed(2) %><% } else { %>Free<% } %>
              </td>
              <td>
                <span class="status-pill status-<%= b.status %>"><%= b.status %></span>
              </td>
              <td><%= new Date(b.bookingDate).toLocaleDateString('en-GB') %></td>
              <td class="text-end">
                <% if (canCancel) { %>
                  <form action="/bookings/<%= b._id %>/cancel" method="POST" class="d-inline"
                        data-confirm="Cancel this booking? Your tickets will be released.">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-x-circle"></i> Cancel
                    </button>
                  </form>
                <% } else if (b.status === 'cancelled') { %>
                  <span class="text-muted small">cancelled</span>
                <% } else { %>
                  <span class="text-muted small">past event</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
