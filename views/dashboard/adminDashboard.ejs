<div class="container py-4">
  <h2 class="mb-1">Admin dashboard</h2>
  <p class="text-muted mb-4">Operational overview at a glance.</p>

  <div class="row g-3 mb-4">
    <div class="col-md-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div>
          <p class="stat-label">Users</p>
          <p class="stat-value"><%= stats.totalUsers %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-calendar-event-fill"></i></div>
        <div>
          <p class="stat-label">Events</p>
          <p class="stat-value"><%= stats.totalEvents %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-ticket-perforated-fill"></i></div>
        <div>
          <p class="stat-label">Bookings</p>
          <p class="stat-value"><%= stats.totalBookings %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-xl">
      <div class="stat-card accent">
        <div class="stat-icon"><i class="bi bi-currency-dollar"></i></div>
        <div>
          <p class="stat-label">Revenue</p>
          <p class="stat-value">R<%= Number(stats.totalRevenue).toFixed(2) %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-inbox-fill"></i></div>
        <div>
          <p class="stat-label">Enquiries</p>
          <p class="stat-value"><%= stats.totalEnquiries %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-6">
      <div class="form-card h-100">
        <h5 class="mb-3"><i class="bi bi-trophy-fill text-warning"></i> Top 5 most popular events</h5>
        <% if (popularEvents.length === 0) { %>
          <p class="text-muted mb-0">No bookings yet.</p>
        <% } else { %>
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Event</th>
                <th class="text-end">Tickets</th>
                <th class="text-end">Bookings</th>
              </tr>
            </thead>
            <tbody>
              <% popularEvents.forEach(function(p) { %>
                <tr>
                  <td>
                    <a href="/events/<%= p.eventId %>" class="text-decoration-none fw-semibold"><%= p.title %></a>
                    <div class="small text-muted"><%= p.category %> · <%= new Date(p.date).toLocaleDateString('en-GB') %></div>
                  </td>
                  <td class="text-end"><strong><%= p.totalTickets %></strong></td>
                  <td class="text-end"><%= p.bookings %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="form-card h-100">
        <h5 class="mb-3"><i class="bi bi-bar-chart-fill text-primary"></i> Capacity usage</h5>
        <% if (capacityEvents.length === 0) { %>
          <p class="text-muted mb-0">No events to display.</p>
        <% } else { %>
          <% capacityEvents.slice(0, 8).forEach(function(ev) {
              const pct = Math.min(100, (ev.ticketsBooked / ev.capacity) * 100);
          %>
            <div class="capacity-row">
              <div class="capacity-label">
                <span><%= ev.title %></span>
                <span class="text-muted"><%= ev.ticketsBooked %> / <%= ev.capacity %></span>
              </div>
              <div class="progress" style="height: 8px;">
                <div class="progress-bar <%= pct >= 100 ? 'bg-danger' : pct >= 75 ? 'bg-warning' : 'bg-primary' %>"
                     style="width: <%= pct %>%"></div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>
