<div class="container py-4">
  <div class="page-header">
    <p class="section-heading mb-1">Overview</p>
    <h2>Admin Dashboard</h2>
  </div>

  <!-- Stat cards -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div>
          <p class="stat-label">Users</p>
          <p class="stat-value"><%= stats.totalUsers %></p>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-calendar-event-fill"></i></div>
        <div>
          <p class="stat-label">Events</p>
          <p class="stat-value"><%= stats.totalEvents %></p>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-ticket-perforated-fill"></i></div>
        <div>
          <p class="stat-label">Bookings</p>
          <p class="stat-value"><%= stats.totalBookings %></p>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl">
      <div class="stat-card accent">
        <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
        <div>
          <p class="stat-label">Revenue</p>
          <p class="stat-value">R<%= Number(stats.totalRevenue).toFixed(0) %></p>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-inbox-fill"></i></div>
        <div>
          <p class="stat-label">Enquiries</p>
          <p class="stat-value"><%= stats.totalEnquiries %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Detail panels -->
  <div class="row g-3">
    <div class="col-lg-6">
      <div class="form-card h-100">
        <p class="section-heading"><i class="bi bi-trophy-fill me-1" style="color:var(--ef-accent);"></i>Top 5 Popular Events</p>
        <% if (popularEvents.length === 0) { %>
          <p style="color:var(--ef-muted);" class="mb-0">No bookings yet.</p>
        <% } else { %>
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Event</th>
                <th class="text-end">Tickets</th>
                <th class="text-end">Bookings</th>
              </tr>
            </thead>
            <tbody>
              <% popularEvents.forEach(function(p, i) { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <span style="font-size:0.75rem;font-weight:700;color:<%= i === 0 ? 'var(--ef-accent)' : 'var(--ef-muted)' %>;">#<%= i+1 %></span>
                      <div>
                        <a href="/events/<%= p.eventId %>" class="fw-semibold" style="color:var(--ef-text);"><%= p.title %></a>
                        <div class="small" style="color:var(--ef-muted);"><%= p.category %> · <%= new Date(p.date).toLocaleDateString('en-GB') %></div>
                      </div>
                    </div>
                  </td>
                  <td class="text-end fw-bold" style="color:var(--ef-accent);"><%= p.totalTickets %></td>
                  <td class="text-end" style="color:var(--ef-muted);"><%= p.bookings %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="form-card h-100">
        <p class="section-heading"><i class="bi bi-bar-chart-fill me-1" style="color:var(--ef-primary);"></i>Capacity Usage</p>
        <% if (capacityEvents.length === 0) { %>
          <p style="color:var(--ef-muted);" class="mb-0">No events to display.</p>
        <% } else { %>
          <% capacityEvents.slice(0, 8).forEach(function(ev) {
              const pct = Math.min(100, (ev.ticketsBooked / ev.capacity) * 100);
          %>
            <div class="capacity-row">
              <div class="capacity-label">
                <span style="font-weight:500;"><%= ev.title %></span>
                <span style="color:var(--ef-muted);font-size:0.8rem;"><%= ev.ticketsBooked %> / <%= ev.capacity %></span>
              </div>
              <div class="progress" style="height:6px;">
                <div class="progress-bar <%= pct >= 100 ? 'bg-danger' : pct >= 75 ? 'bg-warning' : '' %>"
                     style="width:<%= pct %>%;"></div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>
